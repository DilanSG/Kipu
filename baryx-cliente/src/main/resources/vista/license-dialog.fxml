<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Diálogo de licencia expirada/revocada/sin key.
    Se muestra como overlay bloqueante sobre el shell.
    Para EXPIRED/REVOKED no permite continuar sin renovar.
    Para NO_KEY permite ingresar una key de activación.
-->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.baryx.cliente.controlador.LicenseDialogController"
           fx:id="fondoOscuro"
           style="-fx-background-color: rgba(0,0,0,0.82);"
           alignment="CENTER">

    <!-- Tarjeta central -->
    <VBox styleClass="license-dialog-card"
          alignment="CENTER"
          spacing="20"
          maxWidth="560"
          maxHeight="420">

        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Icono de estado -->
        <Region fx:id="iconoEstado"
                styleClass="license-icon"
                minWidth="48" minHeight="48"
                maxWidth="48" maxHeight="48"/>

        <!-- Título -->
        <Label fx:id="lblTitulo"
               styleClass="license-dialog-title"
               wrapText="true"
               maxWidth="480"/>

        <!-- Mensaje -->
        <Label fx:id="lblMensaje"
               styleClass="license-dialog-message"
               wrapText="true"
               maxWidth="480"/>

        <!-- Campo para ingresar key (solo visible en NO_KEY o para reactivar) -->
        <VBox fx:id="panelIngresarKey"
              spacing="8"
              visible="false"
              managed="false">
            <Label text="Clave de licencia:"
                   styleClass="license-dialog-label"/>
            <TextField fx:id="txtLicenseKey"
                       promptText="BRX-XXXXXXXXXXXXXXXXXXXXXXXXXXXX"
                       styleClass="license-key-input"/>
            <Label fx:id="lblErrorKey"
                   styleClass="license-dialog-error"
                   visible="false"
                   managed="false"/>
        </VBox>

        <!-- Botones -->
        <HBox spacing="12" alignment="CENTER">
            <Button fx:id="btnAccionPrimaria"
                    styleClass="login-button-primary"
                    onAction="#accionPrimaria"
                    minWidth="180"/>
            <Button fx:id="btnComprar"
                    styleClass="login-button-secondary"
                    onAction="#irAComprar"
                    visible="false"
                    managed="false"
                    minWidth="160"/>
            <Button fx:id="btnContinuar"
                    text="Continuar de todas formas"
                    styleClass="login-button-secondary"
                    onAction="#continuar"
                    visible="false"
                    managed="false"/>
        </HBox>

        <!-- Modo offline info -->
        <Label fx:id="lblOfflineInfo"
               styleClass="license-dialog-offline"
               wrapText="true"
               maxWidth="480"
               visible="false"
               managed="false"/>

    </VBox>
</StackPane>
