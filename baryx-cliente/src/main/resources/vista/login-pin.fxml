<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import com.baryx.cliente.componente.FondoAnimado?>
<?import com.baryx.cliente.componente.ToggleSwitch?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:id="contenedorPrincipal"
           fx:controller="com.baryx.cliente.controlador.LoginPinController"
           style="-fx-background-color: #0a0a0a;"
           prefHeight="800" prefWidth="1200">

    <FondoAnimado fx:id="fondoAnimado"/>

    <StackPane pickOnBounds="false">
        <padding>
            <Insets top="40" bottom="40"/>
        </padding>

        <VBox fx:id="vistaPIN" alignment="CENTER" spacing="24" styleClass="login-container">
            <padding>
                <Insets top="60" right="60" bottom="60" left="60"/>
            </padding>

            <ImageView fx:id="logoLogin" fitWidth="500" fitHeight="360"
                       preserveRatio="true" styleClass="login-logo-glow">
                <image>
                    <Image url="@../imagenes/LOGOPNG.png"/>
                </image>
            </ImageView>

            <VBox spacing="32" alignment="CENTER" styleClass="login-card" maxWidth="520">
                <padding>
                    <Insets top="48" right="48" bottom="48" left="48"/>
                </padding>

                <VBox fx:id="contenedorTituloCodigo" alignment="CENTER" spacing="8">
                    <Text text="%login.titulo.bienvenido" styleClass="login-title"/>
                    <Text text="%login.titulo.ingrese_codigo" styleClass="login-description"/>
                </VBox>

                <VBox fx:id="contenedorTituloPin" alignment="CENTER" spacing="8"
                      visible="false" managed="false">
                    <Text fx:id="textoNombreEmpleado" text="%login.titulo.bienvenido" styleClass="login-title"/>
                    <Text text="%login.titulo.ingrese_pin" styleClass="login-description"/>
                </VBox>

                <VBox fx:id="formularioCodigo" spacing="24" maxWidth="420" minWidth="420">
                    <TextField fx:id="campoCodigo"
                               styleClass="login-input, login-input-codigo, sin-teclado-virtual"
                               prefHeight="72" alignment="CENTER"
                               focusTraversable="false"
                               style="-fx-font-size: 48px; -fx-font-weight: 700;"/>
                    <Region prefHeight="24"/>
                </VBox>

                <VBox fx:id="formularioPin" spacing="24" maxWidth="420" minWidth="420"
                      visible="false" managed="false">
                    <PasswordField fx:id="campoPin"
                                   styleClass="login-input, login-input-pin, sin-teclado-virtual"
                                   prefHeight="72" alignment="CENTER"
                                   focusTraversable="false"
                                   style="-fx-font-size: 48px; -fx-font-weight: 700;"/>
                    <Region prefHeight="24"/>
                    <Button text="%login.btn.volver" onAction="#volverACodigo"
                            styleClass="login-button-secondary"
                            prefHeight="48" maxWidth="Infinity"/>
                </VBox>

                <HBox fx:id="contenedorCargaPin" alignment="CENTER" spacing="12"
                      visible="false" managed="false">
                    <ProgressIndicator fx:id="indicadorCargaPin"
                                       maxWidth="36" maxHeight="36"
                                       styleClass="login-spinner"/>
                    <Label fx:id="labelCargaPin" text="%login.cargando.verificando"
                           styleClass="login-loading-text"/>
                </HBox>

                <HBox fx:id="contenedorErrorPin" styleClass="login-error-container"
                      visible="false" managed="false" spacing="12" alignment="CENTER_LEFT">
                    <padding>
                        <Insets top="14" right="18" bottom="14" left="18"/>
                    </padding>
                    <Region styleClass="login-error-icono"/>
                    <Label fx:id="labelErrorPin" styleClass="login-error-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>

                <HBox fx:id="contenedorExitoPin" styleClass="login-exito-container"
                      visible="false" managed="false" spacing="12" alignment="CENTER_LEFT">
                    <padding>
                        <Insets top="14" right="18" bottom="14" left="18"/>
                    </padding>
                    <Region styleClass="login-exito-icono"/>
                    <Label fx:id="labelExitoPin" styleClass="login-exito-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
        </VBox>

        <VBox fx:id="vistaAdmin" alignment="CENTER" spacing="24" styleClass="login-container"
              visible="false" managed="false">
            <padding>
                <Insets top="60" right="60" bottom="60" left="60"/>
            </padding>

            <ImageView fitWidth="500" fitHeight="360"
                       preserveRatio="true" styleClass="login-logo-glow">
                <image>
                    <Image url="@../imagenes/LOGOPNG.png"/>
                </image>
            </ImageView>

            <VBox spacing="32" alignment="CENTER" styleClass="login-card" maxWidth="520">
                <padding>
                    <Insets top="48" right="48" bottom="48" left="48"/>
                </padding>

                <VBox alignment="CENTER" spacing="8">
                    <Text text="%login.admin.titulo" styleClass="login-title"/>
                    <Text text="%login.admin.descripcion" styleClass="login-description"/>
                </VBox>

                <VBox spacing="24" maxWidth="420" minWidth="420">

                    <VBox spacing="10">
                        <Label text="%login.admin.label.usuario" styleClass="login-label"/>
                        <TextField fx:id="campoUsuario"
                                   promptText="%login.admin.prompt.usuario"
                                   styleClass="login-input" prefHeight="56"
                                   focusTraversable="false"/>
                    </VBox>

                    <VBox spacing="10">
                        <Label text="%login.admin.label.contrasena" styleClass="login-label"/>
                        <PasswordField fx:id="campoContrasena"
                                       promptText="%login.admin.prompt.contrasena"
                                       styleClass="login-input" prefHeight="56"
                                       focusTraversable="false"/>
                    </VBox>

                    <Region prefHeight="16"/>

                    <Button fx:id="botonLoginAdmin" text="%login.admin.btn.iniciar"
                            onAction="#iniciarSesionAdmin"
                            styleClass="login-button-primary" defaultButton="true"
                            prefHeight="64" maxWidth="Infinity"/>

                    <Button text="%login.admin.btn.volver"
                            onAction="#mostrarLoginPin"
                            styleClass="login-button-secondary"
                            prefHeight="48" maxWidth="Infinity"/>

                    <HBox fx:id="contenedorCargaAdmin" alignment="CENTER" spacing="12"
                          visible="false" managed="false">
                        <ProgressIndicator fx:id="indicadorCargaAdmin"
                                           maxWidth="36" maxHeight="36"
                                           styleClass="login-spinner"/>
                        <Label text="%login.admin.cargando" styleClass="login-loading-text"/>
                    </HBox>

                    <HBox fx:id="contenedorErrorAdmin" styleClass="login-error-container"
                          visible="false" managed="false" spacing="12" alignment="CENTER_LEFT">
                        <padding>
                            <Insets top="14" right="18" bottom="14" left="18"/>
                        </padding>
                        <Region styleClass="login-error-icono"/>
                        <Label fx:id="labelErrorAdmin" styleClass="login-error-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox fx:id="contenedorExitoAdmin" styleClass="login-exito-container"
                          visible="false" managed="false" spacing="12" alignment="CENTER_LEFT">
                        <padding>
                            <Insets top="14" right="18" bottom="14" left="18"/>
                        </padding>
                        <Region styleClass="login-exito-icono"/>
                        <Label fx:id="labelExitoAdmin" styleClass="login-exito-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </StackPane>

    <HBox alignment="TOP_RIGHT" pickOnBounds="false"
          StackPane.alignment="TOP_RIGHT" spacing="12">
        <padding>
            <Insets top="35" right="35"/>
        </padding>
        <Button onAction="#mostrarLoginAdmin"
                styleClass="login-boton-icono"
                style="-fx-padding: 8 12; -fx-opacity: 0.7; -fx-cursor: hand;"
                prefWidth="40" prefHeight="40">
            <graphic>
                <Region styleClass="icono-svg-pequeno, icono-configuracion"
                        style="-fx-background-color: #b0b0b0;"/>
            </graphic>
        </Button>
        <Button onAction="#cerrarAplicacion"
                styleClass="login-boton-icono"
                style="-fx-padding: 8 12; -fx-opacity: 0.7; -fx-cursor: hand;"
                prefWidth="40" prefHeight="40">
            <graphic>
                <Region styleClass="icono-svg-pequeno, icono-cerrar"
                        style="-fx-background-color: #b0b0b0;"/>
            </graphic>
        </Button>
    </HBox>

    <VBox fx:id="contenedorToggleHost" alignment="BOTTOM_LEFT"
          StackPane.alignment="BOTTOM_LEFT" spacing="8"
          pickOnBounds="false" maxWidth="260"
          visible="false" style="-fx-opacity: 0.9;">
        <padding>
            <Insets bottom="50" left="35"/>
        </padding>

        <HBox fx:id="botonExpandirConfig" alignment="CENTER_LEFT" spacing="6"
              visible="false" managed="false"
              style="-fx-cursor: hand; -fx-padding: 6 10;"
              onMouseClicked="#togglePanelConfig">
            <Label text="⚙" style="-fx-text-fill: #d4af37; -fx-font-size: 14px;"/>
            <Label fx:id="labelConfigResumen" text="%login.config.titulo"
                   style="-fx-text-fill: #666666; -fx-font-size: 11px;"/>
        </HBox>

        <VBox fx:id="panelConfigServidor" spacing="8" visible="false" managed="false"
              maxWidth="240"
              style="-fx-background-color: rgba(15,15,15,0.92); -fx-background-radius: 10;
                     -fx-border-color: #333333; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding>
                <Insets top="12" right="14" bottom="12" left="14"/>
            </padding>

            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="%login.config.conexion" style="-fx-text-fill: #d4af37; -fx-font-size: 10px;
                       -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="▾" style="-fx-text-fill: #666; -fx-font-size: 12px; -fx-cursor: hand;"
                       onMouseClicked="#colapsarPanelConfig"/>
            </HBox>

            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="%login.config.ip" style="-fx-text-fill: #777; -fx-font-size: 10px;"
                       minWidth="42" prefWidth="42"/>
                <TextField fx:id="campoIpServidor" promptText="192.168.1.100"
                           prefWidth="155" prefHeight="26" maxWidth="155"
                           style="-fx-background-color: #1a1a1a; -fx-text-fill: #e8e8e8;
                                  -fx-border-color: #404040; -fx-border-radius: 4;
                                  -fx-background-radius: 4; -fx-font-size: 11px;
                                  -fx-prompt-text-fill: #555; -fx-padding: 3 6;"/>
            </HBox>

            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="%login.config.puerto" style="-fx-text-fill: #777; -fx-font-size: 10px;"
                       minWidth="42" prefWidth="42"/>
                <TextField fx:id="campoPuertoServidor" text="8080"
                           prefWidth="155" prefHeight="26" maxWidth="155"
                           style="-fx-background-color: #1a1a1a; -fx-text-fill: #e8e8e8;
                                  -fx-border-color: #404040; -fx-border-radius: 4;
                                  -fx-background-radius: 4; -fx-font-size: 11px;
                                  -fx-prompt-text-fill: #555; -fx-padding: 3 6;"/>
            </HBox>

            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="%login.config.equipo" style="-fx-text-fill: #777; -fx-font-size: 10px;"
                       minWidth="42" prefWidth="42"/>
                <TextField fx:id="campoNombreCliente" promptText="Caja 1"
                           prefWidth="155" prefHeight="26" maxWidth="155"
                           style="-fx-background-color: #1a1a1a; -fx-text-fill: #e8e8e8;
                                  -fx-border-color: #404040; -fx-border-radius: 4;
                                  -fx-background-radius: 4; -fx-font-size: 11px;
                                  -fx-prompt-text-fill: #555; -fx-padding: 3 6;"/>
            </HBox>

            <HBox spacing="6" alignment="CENTER_LEFT">
                <Button fx:id="botonProbarConexion" text="%login.config.conectar"
                        onAction="#probarConexionServidor"
                        prefHeight="26" prefWidth="75"
                        style="-fx-background-color: #2a2a2a; -fx-text-fill: #d4af37;
                               -fx-border-color: #d4af37; -fx-border-radius: 4;
                               -fx-background-radius: 4; -fx-font-size: 10px;
                               -fx-cursor: hand;"/>
                <Label fx:id="labelResultadoConexion" text=""
                       style="-fx-font-size: 10px; -fx-text-fill: #999;"/>
            </HBox>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <ToggleSwitch fx:id="toggleHostMode"/>
            <Label fx:id="labelHostMode" text="%login.config.modo_host"
                   style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
        </HBox>
    </VBox>

    <HBox alignment="CENTER_RIGHT" StackPane.alignment="BOTTOM_RIGHT"
          pickOnBounds="false" maxHeight="40">
        <padding>
            <Insets bottom="50" right="35"/>
        </padding>
        <HBox fx:id="indicadorConexionLogin" alignment="CENTER" spacing="6"
              style="-fx-padding: 8 14; -fx-background-color: rgba(0,0,0,0.5); -fx-background-radius: 20;"/>
    </HBox>

    <HBox alignment="CENTER" StackPane.alignment="BOTTOM_CENTER"
          pickOnBounds="false" maxHeight="30">
        <padding>
            <Insets bottom="10"/>
        </padding>
        <HBox alignment="CENTER" spacing="16">
            <Label fx:id="labelVersion" text="%login.version" styleClass="login-footer-text"/>
            <Label text="•" styleClass="login-footer-separator"/>
            <Label text="%login.copyright" styleClass="login-footer-text"/>
        </HBox>
    </HBox>

</StackPane>
