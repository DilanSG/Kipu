<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<!--
    Banner no-intrusivo de nueva versión disponible.
    Se muestra en la parte superior del shell como overlay adicional.
    El controlador lo oculta cuando el usuario hace clic en "X".
-->
<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.baryx.cliente.controlador.UpdateBannerController"
      fx:id="bannerRaiz"
      styleClass="update-banner"
      alignment="CENTER_LEFT"
      spacing="12"
      StackPane.alignment="TOP_CENTER">

    <padding>
        <Insets top="10" right="16" bottom="10" left="16"/>
    </padding>

    <!-- Icono -->
    <Region styleClass="update-banner-icon" minWidth="20" minHeight="20" maxWidth="20" maxHeight="20"/>

    <!-- Mensaje -->
    <Label fx:id="lblMensaje"
           styleClass="update-banner-text"
           wrapText="false"/>

    <Region HBox.hgrow="ALWAYS"/>

    <!-- Botón ir a descargas -->
    <Button fx:id="btnDescargar"
            styleClass="update-banner-btn"
            onAction="#abrirDescarga"/>

    <!-- Cerrar -->
    <Button text="✕"
            styleClass="update-banner-close"
            onAction="#cerrar"/>

</HBox>
