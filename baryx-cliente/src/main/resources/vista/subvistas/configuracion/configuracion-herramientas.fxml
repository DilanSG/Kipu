<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- SUBVISTA: CONFIGURACIONES Y HERRAMIENTAS
     Panel estilo Windows 8 con tiles/cards pequeñas organizadas en grid.
     Muestra todas las opciones de configuración del sistema agrupadas por sección.
     Solo accesible por rol ADMIN.
-->
<StackPane fx:id="contenedorRaiz"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.baryx.cliente.controlador.configuracion.ConfiguracionHerramientasController"
           styleClass="contenedor-centro">

    <VBox spacing="16">
        <padding>
            <Insets top="24" right="32" bottom="24" left="32"/>
        </padding>

        <!-- Header compacto -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Region styleClass="icono-cfg-header"
                    prefWidth="20" prefHeight="20"
                    minWidth="20" minHeight="20"
                    maxWidth="20" maxHeight="20"/>
            <Label text="%config.titulo.herramientas_principal" 
                   style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #d4af37;"/>
        </HBox>

        <!-- Contenedor de columnas con scroll horizontal -->
        <ScrollPane fitToWidth="false" fitToHeight="false"
                    hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    styleClass="edge-to-edge"
                    VBox.vgrow="ALWAYS">
            <content>
                <HBox spacing="24" alignment="TOP_LEFT" style="-fx-padding: 4 8 16 4;">

                    <!-- ═══ COLUMNA: SISTEMA ═══ -->
                    <VBox spacing="10" styleClass="config-columna">
                        <Label text="%config.seccion.sistema" styleClass="config-seccion-titulo"/>
                        <VBox fx:id="seccionSistema" spacing="10"/>
                    </VBox>

                    <!-- ═══ COLUMNA: EMPRESA Y LOCALES ═══ -->
                    <VBox spacing="10" styleClass="config-columna">
                        <Label text="%config.seccion.empresa" styleClass="config-seccion-titulo"/>
                        <VBox fx:id="seccionEmpresa" spacing="10"/>
                    </VBox>

                    <!-- ═══ COLUMNA: PUNTO DE VENTA ═══ -->
                    <VBox spacing="10" styleClass="config-columna">
                        <Label text="%config.seccion.punto_venta" styleClass="config-seccion-titulo"/>
                        <VBox fx:id="seccionPuntoVenta" spacing="10"/>
                    </VBox>

                    <!-- ═══ COLUMNA: PERSONAL ═══ -->
                    <VBox spacing="10" styleClass="config-columna">
                        <Label text="%config.seccion.personal" styleClass="config-seccion-titulo"/>
                        <VBox fx:id="seccionPersonal" spacing="10"/>
                    </VBox>

                    <!-- ═══ COLUMNA: DATOS Y REPORTES ═══ -->
                    <VBox spacing="10" styleClass="config-columna">
                        <Label text="%config.seccion.datos" styleClass="config-seccion-titulo"/>
                        <VBox fx:id="seccionDatos" spacing="10"/>
                    </VBox>

                    <!-- ═══ COLUMNA: SEGURIDAD ═══ -->
                    <VBox spacing="10" styleClass="config-columna">
                        <Label text="%config.seccion.seguridad" styleClass="config-seccion-titulo"/>
                        <VBox fx:id="seccionSeguridad" spacing="10"/>
                    </VBox>

                    <!-- ═══ COLUMNA: HERRAMIENTAS ═══ -->
                    <VBox spacing="10" styleClass="config-columna">
                        <Label text="%config.seccion.herramientas" styleClass="config-seccion-titulo"/>
                        <VBox fx:id="seccionHerramientas" spacing="10"/>
                    </VBox>

                </HBox>
            </content>
        </ScrollPane>

    </VBox>
</StackPane>
