<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import com.baryx.cliente.componente.ToggleSwitch?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.baryx.cliente.controlador.facturacion.MesaDetalleController"
           styleClass="contenedor-centro">
    
    <VBox spacing="0" VBox.vgrow="ALWAYS">
        
        <HBox styleClass="header-detalle-mesa" alignment="CENTER_LEFT" spacing="40">
            <padding>
                <Insets top="16" right="32" bottom="16" left="32"/>
            </padding>
            
            <VBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                <Label fx:id="txtNumeroMesa" text="MESA 10" 
                       styleClass="mesa-numero-texto"/>
                <Label fx:id="txtMesero" text="Mesero: JOSSELIN GUTIERREZ" 
                       styleClass="mesa-mesero-texto"/>
            </VBox>
            
            <Button text="%mesa.detalle.btn.volver"
                    onAction="#volverAtras"
                    styleClass="btn-devolver-mesa"
                    prefHeight="30" prefWidth="90"
            />
        </HBox>
        
        <Separator styleClass="separador-gris"/>
        
        <HBox spacing="0" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
            
            <StackPane prefWidth="400" minWidth="400" maxWidth="400" styleClass="fondo-panel-pedido">
                
                <VBox styleClass="panel-pedido-detalle-content">
                    <padding>
                        <Insets top="20" right="15" bottom="20" left="20"/>
                    </padding>
                    
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <padding>
                            <Insets bottom="15"/>
                        </padding>
                        <Label text="%mesa.detalle.pedido_actual" styleClass="titulo-panel-sm"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="%mesa.detalle.agrupar" styleClass="texto-secundario-sm"/>
                        <ToggleSwitch fx:id="toggleVistaResumida"/>
                    </HBox>
                    
                    <ScrollPane fitToWidth="true" styleClass="scroll-productos-pedido" VBox.vgrow="ALWAYS">
                        <VBox spacing="3">
                            
                            <HBox styleClass="tabla-pedido-header" spacing="5">
                                <padding>
                                    <Insets top="10" right="8" bottom="10" left="8"/>
                                </padding>
                                <Label text="%mesa.detalle.col.numero" styleClass="tabla-col-dorado" prefWidth="35" minWidth="35" maxWidth="35"/>
                                <Label text="%mesa.detalle.col.producto" styleClass="tabla-col-dorado" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                                <Label text="%mesa.detalle.col.cantidad" styleClass="tabla-col-dorado" prefWidth="50" minWidth="50" maxWidth="50" alignment="CENTER"/>
                                <Label text="%mesa.detalle.col.precio" styleClass="tabla-col-dorado" prefWidth="90" minWidth="90" maxWidth="90" alignment="CENTER_RIGHT"/>
                            </HBox>

                            <VBox fx:id="listaPedido" spacing="2" styleClass="lista-items-pedido"/>
                            
                        </VBox>
                    </ScrollPane>
                    
                    <VBox spacing="12" styleClass="seccion-total">
                        <padding>
                            <Insets top="20"/>
                        </padding>
                        
                        <Separator styleClass="separador-dorado-grueso"/>
                        
                        <HBox alignment="CENTER" spacing="15">
                            <padding>
                                <Insets top="5" bottom="5"/>
                            </padding>
                            <Label text="%mesa.detalle.total" styleClass="total-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="txtTotal" text="0.00" styleClass="total-valor-dorado"/>
                        </HBox>
                    </VBox>
                </VBox>
            </StackPane>
            
            <StackPane fx:id="contenedorPrincipal" styleClass="panel-categorias-detalle" HBox.hgrow="ALWAYS">
                
                <VBox fx:id="panelCategoriasProductos" visible="true" managed="true">
                    <HBox spacing="0" VBox.vgrow="ALWAYS">
                        
                        <StackPane prefWidth="450" minWidth="400" maxWidth="500" styleClass="fondo-panel-categorias">
                            
                            <VBox spacing="15" styleClass="panel-categorias-lateral-content">
                                <padding>
                                    <Insets top="20" right="15" bottom="0" left="15"/>
                                </padding>
                                <Label text="%mesa.detalle.btn.categorias" styleClass="titulo-panel-md"/>
                                
                                <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="scroll-categorias-detalle" VBox.vgrow="ALWAYS">
                                    <GridPane fx:id="gridCategorias" 
                                            hgap="15" vgap="15"
                                            styleClass="grid-categorias-productos">
                                        <padding>
                                            <Insets top="5" right="5" bottom="15" left="5"/>
                                        </padding>
                                    </GridPane>
                                </ScrollPane>
                            </VBox>
                        </StackPane>
                        
                        <Region styleClass="separador-vertical-mesa" HBox.hgrow="NEVER"/>
                        
                        <StackPane HBox.hgrow="ALWAYS" styleClass="fondo-panel-productos">
                            
                            <VBox spacing="15" styleClass="panel-productos-lateral-content">
                                <padding>
                                    <Insets top="20" right="15" bottom="0" left="15"/>
                                </padding>
                                <Label fx:id="lblTituloProductos" text="%mesa.detalle.selecciona_categoria" 
                                       styleClass="titulo-panel-gris"/>
                                
                                <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="scroll-categorias-detalle" VBox.vgrow="ALWAYS">
                                    <GridPane fx:id="gridProductos" 
                                            hgap="4" vgap="4"
                                            styleClass="grid-categorias-productos">
                                        <padding>
                                            <Insets top="5" right="5" bottom="15" left="5"/>
                                        </padding>
                                    </GridPane>
                                </ScrollPane>
                            </VBox>
                        </StackPane>
                        
                    </HBox>
                </VBox>

                <StackPane fx:id="panelPago" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    
                    <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="scroll-productos-pedido" VBox.vgrow="ALWAYS">
                        <VBox spacing="40" alignment="TOP_CENTER">
                            <padding>
                                <Insets top="50" right="40" bottom="40" left="40"/>
                            </padding>
                            
                            <!-- PANEL 1: RESUMEN SIMPLE (Vista inicial) -->
                            <VBox fx:id="panelResumenSimple" spacing="0" alignment="CENTER" maxWidth="700">
                                
                                <!-- Card contenedor con estilo elegante -->
                                <VBox spacing="0" styleClass="card-resumen-cuenta">
                                    <padding>
                                        <Insets top="40" right="50" bottom="40" left="50"/>
                                    </padding>
                                    
                                    <!-- Título elegante -->
                                    <VBox spacing="8" alignment="CENTER">
                                        <padding>
                                            <Insets bottom="30"/>
                                        </padding>
                                        <Label text="%mesa.detalle.resumen_cuenta" 
                                               styleClass="resumen-titulo"/>
                                        <Separator prefWidth="200" styleClass="separador-dorado-grueso"/>
                                    </VBox>
                                    
                                    <!-- Items del resumen en formato vertical -->
                                    <VBox spacing="0">
                                        
                                        <!-- Subtotal -->
                                        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="resumen-fila">
                                            <Label text="%mesa.detalle.subtotal" 
                                                   styleClass="resumen-label"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label fx:id="lblSubtotalResumen" text="0.00" 
                                                   styleClass="resumen-valor"/>
                                        </HBox>
                                        
                                        <Separator styleClass="separador-sutil"/>
                                        
                                        <!-- Impoconsumo -->
                                        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="resumen-fila">
                                            <Label text="%mesa.detalle.impoconsumo" 
                                                   styleClass="resumen-label"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label fx:id="lblImpoconsumoResumen" text="0.00" 
                                                   styleClass="resumen-valor"/>
                                        </HBox>
                                        
                                        <Separator styleClass="separador-sutil"/>
                                        
                                        <!-- Total sin propina -->
                                        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="resumen-fila">
                                            <Label text="%mesa.detalle.total_sin_propina" 
                                                   styleClass="resumen-label"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label fx:id="lblTotalSinPropinaResumen" text="0.00" 
                                                   styleClass="resumen-valor"/>
                                        </HBox>
                                        
                                        <Separator styleClass="separador-sutil"/>
                                        
                                        <!-- Propina sugerida con selector de porcentaje -->
                                        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="resumen-fila">
                                            <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                                <Label text="%mesa.detalle.propina_sugerida" 
                                                       styleClass="resumen-label"/>
                                                <Button fx:id="btnPorcentajePropina" text="(10%)" 
                                                        onAction="#seleccionarPorcentajePropina"
                                                        styleClass="btn-porcentaje-propina"
                                                        onMouseEntered="#onHoverPorcentaje"
                                                        onMouseExited="#onExitPorcentaje"/>
                                            </HBox>
                                            <Label fx:id="lblPropinaResumen" text="0.00" 
                                                   styleClass="resumen-valor"/>
                                        </HBox>
                                        
                                        <!-- Separador destacado antes del total -->
                                        <Separator styleClass="separador-dorado-tenue">
                                            <VBox.margin>
                                                <Insets top="15" bottom="15"/>
                                            </VBox.margin>
                                        </Separator>
                                        
                                        <!-- Total a pagar - Destacado -->
                                        <HBox alignment="CENTER" spacing="20" styleClass="resumen-fila-total">
                                            <Label text="%mesa.detalle.total_a_pagar" 
                                                   styleClass="resumen-total-titulo"/>
                                            <Label fx:id="lblTotalFinalResumen" text="0.00" 
                                                   styleClass="resumen-total-valor"/>
                                        </HBox>
                                        
                                    </VBox>
                                    
                                    <!-- Botón de acción principal -->
                                    <VBox alignment="CENTER">
                                        <padding>
                                            <Insets top="35"/>
                                        </padding>
                                        <Button text="%mesa.detalle.btn.proceder_pago" 
                                                onAction="#irAPanelMetodosPago"
                                                styleClass="boton-principal, btn-proceder-pago"
                                                prefWidth="500" prefHeight="70"/>
                                    </VBox>
                                    
                                </VBox>
                            </VBox>
                            
                            <!-- PANEL 2: MÉTODOS DE PAGO Y GRID (Vista detallada, oculta inicialmente) -->
                            <VBox fx:id="panelMetodosPagoDetalle" spacing="15" alignment="CENTER" visible="false" managed="false">
                                
                            <!-- MÉTODOS DE PAGO - Botones dinámicos -->
                            <VBox spacing="15" alignment="CENTER">
                                
                                <!-- Contenedor dinámico para botones de métodos de pago -->
                                <HBox fx:id="contenedorBotonesMetodosPago" spacing="0" alignment="CENTER">
                                    <!-- Los botones se generan dinámicamente desde el controlador -->
                                </HBox>
                            </VBox>
                            
                            <Separator styleClass="separador-dorado-suave"/>
                            
                            <!-- RESUMEN Y PAGOS EN CUADRÍCULA UNIFICADA -->
                            <VBox spacing="15" alignment="CENTER" HBox.hgrow="ALWAYS">
                                <Label text="%mesa.detalle.resumen_pago" 
                                       styleClass="titulo-panel-md"/>
                                
                                <!-- Contenedor con estilo de tabla -->
                                <VBox styleClass="grid-tabla-pagos" alignment="CENTER" maxWidth="1.7976931348623157E308">
                                    <padding>
                                        <Insets top="0" right="0" bottom="0" left="0"/>
                                    </padding>
                                    
                                    <!-- GridPane unificado: Cards principales + Pagos registrados -->
                                    <GridPane fx:id="gridResumenPagos" styleClass="grid-pagos-contenido" 
                                              hgap="1" vgap="1" alignment="CENTER" maxWidth="1.7976931348623157E308">
                                        <!-- Fila 0: Headers -->
                                        
                                        <!-- Columna 0: Subtotal (sin impuestos) -->
                                        <VBox spacing="8" alignment="CENTER" styleClass="celda-grid-header" 
                                              prefHeight="100" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                                            <padding>
                                                <Insets top="12" right="12" bottom="12" left="12"/>
                                            </padding>
                                            <Label text="%mesa.detalle.grid.subtotal" 
                                                   styleClass="grid-header-dorado"/>
                                            <Label fx:id="lblSubtotalPago" text="0" 
                                                   styleClass="grid-valor"/>
                                        </VBox>
                                        
                                        <!-- Columna 1: Impoconsumo 8% -->
                                        <VBox spacing="8" alignment="CENTER" styleClass="celda-grid-header" 
                                              prefHeight="100" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                                            <padding>
                                                <Insets top="12" right="12" bottom="12" left="12"/>
                                            </padding>
                                            <Label text="%mesa.detalle.grid.impoconsumo" 
                                                   styleClass="grid-header-dorado"/>
                                            <Label fx:id="lblImpoconsumo" text="0" 
                                                   styleClass="grid-valor"/>
                                        </VBox>
                                        
                                        <!-- Columna 2: Total sin propina (Subtotal + Impoconsumo) -->
                                        <VBox spacing="8" alignment="CENTER" styleClass="celda-grid-header" 
                                              prefHeight="100" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                                            <padding>
                                                <Insets top="12" right="12" bottom="12" left="12"/>
                                            </padding>
                                            <Label text="%mesa.detalle.grid.total_sin_propina" 
                                                   styleClass="grid-header-dorado-sm"/>
                                            <Label fx:id="lblTotalSinPropina" text="0" 
                                                   styleClass="grid-valor"/>
                                        </VBox>
                                        
                                        <!-- Columna 3: Propina (muestra total acumulado de propinas) -->
                                        <VBox spacing="8" alignment="CENTER" styleClass="celda-grid-header" 
                                              prefHeight="100" GridPane.columnIndex="3" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                                            <padding>
                                                <Insets top="12" right="12" bottom="12" left="12"/>
                                            </padding>
                                            <Label fx:id="lblTextoPropinaHeader" text="PROPINA (10%)" 
                                                   styleClass="grid-header-dorado"/>
                                            <Label fx:id="lblPropinaTotalHeader" text="0" 
                                                   styleClass="grid-valor"/>
                                        </VBox>
                                        
                                        <!-- Columna 4: Total -->
                                        <VBox spacing="8" alignment="CENTER" styleClass="celda-grid-header" 
                                              prefHeight="100" GridPane.columnIndex="4" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                                            <padding>
                                                <Insets top="12" right="12" bottom="12" left="12"/>
                                            </padding>
                                            <Label text="%mesa.detalle.grid.total" 
                                                   styleClass="grid-header-dorado"/>
                                            <Label fx:id="lblTotalPago" text="0" 
                                                   styleClass="grid-total-dorado"/>
                                        </VBox>
                                        
                                        <!-- Columna 5: Acciones (Botón Pagar) -->
                                        <VBox spacing="8" alignment="CENTER" styleClass="celda-grid-header" 
                                              prefHeight="100" GridPane.columnIndex="5" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                                            <padding>
                                                <Insets top="12" right="12" bottom="12" left="12"/>
                                            </padding>
                                            <Button fx:id="btnConfirmarPago" text="%mesa.detalle.btn.pagar" 
                                                    onAction="#confirmarPago"
                                                    styleClass="boton-principal, btn-confirmar-pago"
                                                    prefWidth="150" prefHeight="60"/>
                                        </VBox>
                                        
                                        <!-- Filas 1+: Pagos registrados (agregados dinámicamente desde el controlador) -->
                                    </GridPane>
                                </VBox>
                                
                            </VBox>
                            </VBox>  <!-- Cierre panelMetodosPagoDetalle -->
                            
                            <Region VBox.vgrow="ALWAYS"/>
                        </VBox>
                    </ScrollPane>
                    
                    <!-- X flotante esquina superior derecha del panel completo -->
                    <Button fx:id="btnCerrarPago1" text="✕" onAction="#cerrarPanelActual"
                            styleClass="boton-secundario, btn-cerrar-panel"
                            StackPane.alignment="TOP_RIGHT">
                        <StackPane.margin>
                            <Insets top="12" right="16"/>
                        </StackPane.margin>
                    </Button>
                    
                    <!-- Título flotante "Método de Pago" visible solo en panel 2 -->
                    <Label fx:id="lblTituloMetodoPagoFlotante" text="%mesa.detalle.metodo_pago"
                           styleClass="titulo-dorado-lg" visible="false" managed="false"
                           StackPane.alignment="TOP_LEFT">
                        <StackPane.margin>
                            <Insets top="16" left="24"/>
                        </StackPane.margin>
                    </Label>
                </StackPane>
                
            </StackPane>
        </HBox>
        
        <Separator fx:id="separadorBarraAcciones" styleClass="separador-gris"/>
        
        <!-- Barra de acciones -->
        <StackPane fx:id="barraAcciones" minHeight="88" maxHeight="88" prefHeight="88">
            
            <HBox styleClass="barra-acciones-detalle" alignment="CENTER_LEFT" spacing="12" minHeight="88" maxHeight="88" prefHeight="88">
                <padding>
                    <Insets top="16" right="24" bottom="16" left="24"/>
                </padding>
                
                <Button styleClass="btn-accion-mesa" 
                        onAction="#mostrarPanelPago" prefHeight="56" prefWidth="140">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Region styleClass="icono-mesa-accion, icono-facturar"/>
                            <Label text="%mesa.detalle.btn.facturar" styleClass="texto-accion-btn"/>
                        </HBox>
                    </graphic>
                </Button>
                
                <Button styleClass="btn-accion-mesa" 
                        onAction="#aplicarDescuento" prefHeight="56" prefWidth="140">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Region styleClass="icono-mesa-accion, icono-descuento"/>
                            <Label text="%mesa.detalle.btn.descuento" styleClass="texto-accion-btn"/>
                        </HBox>
                    </graphic>
                </Button>
                
                
                <Button styleClass="btn-accion-mesa" 
                        onAction="#buscarProducto" prefHeight="56" prefWidth="130">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Region styleClass="icono-mesa-accion, icono-buscar-mesa"/>
                            <Label text="%mesa.detalle.btn.buscar" styleClass="texto-accion-btn"/>
                        </HBox>
                    </graphic>
                </Button>
                
                <Button styleClass="btn-accion-mesa" 
                        onAction="#asignarFormaPago" prefHeight="56" prefWidth="160">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Region styleClass="icono-mesa-accion, icono-forma-pago"/>
                            <Label text="%mesa.detalle.btn.forma_pago" styleClass="texto-accion-btn"/>
                        </HBox>
                    </graphic>
                </Button>
                
                <Button styleClass="btn-accion-mesa" 
                        onAction="#anularCuenta" prefHeight="56" prefWidth="180">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Region styleClass="icono-mesa-accion, icono-anular"/>
                            <Label text="%mesa.detalle.btn.anular_cuenta" styleClass="texto-accion-btn"/>
                        </HBox>
                    </graphic>
                </Button>
                
                <Region HBox.hgrow="ALWAYS"/>

                <Button styleClass="btn-accion-mesa" 
                        onAction="#mostrarMasOpciones" prefHeight="56" prefWidth="100">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Region styleClass="icono-mesa-accion, icono-mas-opciones"/>
                            <Label text="%mesa.detalle.btn.mas" styleClass="texto-accion-btn"/>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>
        </StackPane>
    </VBox>
    
    <StackPane fx:id="contenedorModal" 
               visible="false" 
               managed="false"
               styleClass="modal-fondo-oscuro"
               alignment="CENTER">
        <StackPane fx:id="contenidoModalInterno" 
                   maxWidth="700" 
                   maxHeight="850"/>
    </StackPane>
    
</StackPane>
