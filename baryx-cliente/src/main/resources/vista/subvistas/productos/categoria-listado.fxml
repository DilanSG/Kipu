<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.baryx.cliente.componente.LineaDivisoriaInteractiva?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.baryx.cliente.controlador.productos.CategoriaListadoController"
           styleClass="contenedor-centro">

    <VBox alignment="TOP_CENTER" spacing="32">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <VBox alignment="CENTER" spacing="16">
            <HBox alignment="CENTER" spacing="16">
                <Label text="%productos.categorias.listado.titulo" styleClass="productos-titulo"/>
            </HBox>
            <LineaDivisoriaInteractiva maxWidth="600"/>
        </VBox>

        <VBox alignment="TOP_CENTER" VBox.vgrow="ALWAYS" maxWidth="Infinity">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" 
                        maxWidth="640" VBox.vgrow="ALWAYS" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" styleClass="edge-to-edge">
                <content>
                    <FlowPane fx:id="contenedorCategorias" 
                              hgap="24" vgap="24" 
                              alignment="TOP_CENTER" 
                              maxWidth="640"
                              style="-fx-padding: 30;">
                    </FlowPane>
                </content>
            </ScrollPane>
        </VBox>
    </VBox>

    <HBox alignment="BOTTOM_LEFT" pickOnBounds="false" mouseTransparent="true">
        <padding>
            <Insets bottom="20" left="40"/>
        </padding>
        <VBox alignment="BOTTOM_LEFT" spacing="2">
            <Label text="%productos.info" style="-fx-text-fill: #ffefbb7b; -fx-font-weight: bold; -fx-font-size: 11px;"/>
            <Label text="%productos.categorias.listado.info" 
                   style="-fx-text-fill: #ffefbb; -fx-font-size: 13px; -fx-font-style: italic;"/>
        </VBox>
    </HBox>

    <StackPane fx:id="contenedorModal" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.7);">
        <StackPane fx:id="contenidoModalInterno" maxWidth="-Infinity" maxHeight="-Infinity">
        </StackPane>
    </StackPane>
</StackPane>
