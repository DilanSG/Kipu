<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.baryx.cliente.componente.LineaDivisoriaInteractiva?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.baryx.cliente.controlador.productos.ProductoCrearController"
           styleClass="contenedor-centro">
    
    <VBox alignment="TOP_CENTER" spacing="32" styleClass="content-container">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
    
    <Label text="%productos.crear.titulo" styleClass="productos-titulo"/>
    
    <LineaDivisoriaInteractiva maxWidth="400"/>
    
    <VBox spacing="24" alignment="TOP_CENTER" maxWidth="600" styleClass="formulario-container">
        
        <VBox spacing="8" maxWidth="Infinity">
            <Label text="%productos.crear.nombre" styleClass="label-formulario"/>
            <TextField fx:id="txtNombre" 
                      styleClass="campo-texto-formulario"
                      prefHeight="50"/>
            <Label fx:id="errorNombre"
                   styleClass="error-texto"
                   visible="false"
                   managed="false"/>
        </VBox>
        
        
        <VBox spacing="8" maxWidth="Infinity">
            <Label text="%productos.crear.precio" styleClass="label-formulario"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="txtPrecio" 
                          styleClass="campo-texto-formulario"
                          prefHeight="50"
                          HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label fx:id="errorPrecio"
                   styleClass="error-texto"
                   visible="false"
                   managed="false"/>
        </VBox>
        
        <VBox spacing="8" maxWidth="Infinity">
            <Label text="%productos.crear.categoria" styleClass="label-formulario"/>
            <ComboBox fx:id="comboCategoria"
                     promptText="%productos.crear.categoria.prompt"
                     styleClass="combo-formulario"
                     prefHeight="50"
                     maxWidth="Infinity">
            </ComboBox>
            <Label fx:id="errorCategoria"
                   styleClass="error-texto"
                   visible="false"
                   managed="false"/>
        </VBox>
        
        <VBox spacing="8" styleClass="info-box">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <Label text="%productos.crear.info.titulo" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #eed600ff;"/>
            <Label text="%productos.crear.info.desc"
                   wrapText="true"
                   style="-fx-font-size: 13px; -fx-text-fill: #b0b0b0;"/>
        </VBox>
        
    </VBox>
    
    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 20 0 0 0;">
        <Button text="%productos.btn.cancelar" 
                onAction="#cancelar"
                styleClass="boton-secundario-formulario"
                prefWidth="180"
                prefHeight="55"/>
        
        <Button text="%productos.crear.btn.guardar" 
                onAction="#guardar"
                styleClass="boton-principal-formulario"
                prefWidth="250"
                prefHeight="55"/>
    </HBox>
    
    </VBox>
</StackPane>
