# Archivo de ejemplo para variables de entorno
# Copiar este archivo a .env y modificar los valores según sea necesario
# --- Base de Datos (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kipu_db
DB_USER=kipu_admin
DB_PASSWORD=CAMBIAR_CONTRASEÑA_AQUI

# --- Seguridad (JWT) ---
# Usar una cadena aleatoria larga (mínimo 32 caracteres)
JWT_SECRET=CAMBIAR_CLAVE_SECRETA_AQUI

# --- Servidor ---
SERVER_PORT=8080

# --- Cliente ---
# URL completa del servidor (para clientes remotos en la LAN)
SERVER_URL=http://localhost:8080

# --- Perfil Spring Boot ---
# Opciones: dev, prod
SPRING_PROFILES_ACTIVE=dev
