#!/bin/bash
# Post-instalacion de Kipu
# Se ejecuta automaticamente despues de instalar el paquete .deb

set -e

# Asegurar permisos de ejecucion
chmod +x /opt/kipu/cliente/bin/Kipu 2>/dev/null || true
chmod +x /opt/kipu/servidor/bin/KipuServidor 2>/dev/null || true
chmod +x /opt/kipu/servidor/setup-inicial.sh 2>/dev/null || true
chmod +x /opt/kipu/iniciar-cliente.sh 2>/dev/null || true
chmod +x /opt/kipu/iniciar-servidor.sh 2>/dev/null || true

# Crear symlinks en /usr/local/bin para acceso por terminal
ln -sf /opt/kipu/cliente/bin/Kipu /usr/local/bin/kipu 2>/dev/null || true
ln -sf /opt/kipu/iniciar-cliente.sh /usr/local/bin/kipu-cliente 2>/dev/null || true
ln -sf /opt/kipu/iniciar-servidor.sh /usr/local/bin/kipu-servidor 2>/dev/null || true

# Actualizar cache de iconos y base de datos de aplicaciones
if command -v update-desktop-database &> /dev/null; then
    update-desktop-database /usr/share/applications 2>/dev/null || true
fi
if command -v gtk-update-icon-cache &> /dev/null; then
    gtk-update-icon-cache -f -t /usr/share/icons/hicolor 2>/dev/null || true
fi

echo ""
echo "  Kipu instalado correctamente."
echo ""
echo "  Para configurar la base de datos (primera vez):"
echo "    sudo /opt/kipu/servidor/setup-inicial.sh"
echo ""
echo "  Para iniciar Kipu:"
echo "    - Desde el menu de aplicaciones"
echo "    - O ejecute: kipu"
echo ""
echo "  Para iniciar con logs en consola:"
echo "    - Cliente:  kipu-cliente"
echo "    - Servidor: kipu-servidor"
echo ""
