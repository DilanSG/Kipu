<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.kipu.cliente.controlador.BannerRenovacionController"
      styleClass="renewal-banner"
      alignment="CENTER"
      spacing="12">

    <Label fx:id="labelIcono" text="⚠" styleClass="renewal-banner-icon"/>
    <Label fx:id="labelTexto" styleClass="renewal-banner-text"/>
    <Button fx:id="btnRenovar" styleClass="renewal-banner-btn" onAction="#abrirTienda"/>
    <Button fx:id="btnCerrar" text="✕" styleClass="renewal-banner-close" onAction="#cerrarBanner"/>

</HBox>
