<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import com.kipu.cliente.componente.FondoAnimado?>
<?import com.kipu.cliente.componente.LineaDivisoriaInteractiva?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.kipu.cliente.controlador.MenuPrincipalController"
            styleClass="menu-root">
    
    <top>
        <VBox fx:id="headerGeneral">
            <StackPane>
                <FondoAnimado colorCentro="#0a0a0a" colorIntermedio="#0a0a0a" colorBorde="#0a0a0a"/>
                <HBox styleClass="menu-header" alignment="CENTER_LEFT" spacing="24">
                    <padding>
                        <Insets top="20" right="32" bottom="20" left="32"/>
                    </padding>
                    
                    <StackPane alignment="CENTER_LEFT">
                        <ImageView fx:id="logoHeader" fitWidth="120" fitHeight="50" preserveRatio="true">
                            <image>
                                <Image url="@../imagenes/LOGO.png"/>
                            </image>
                        </ImageView>
                        
                        <HBox fx:id="breadcrumbsBar" styleClass="breadcrumbs-container-header" alignment="CENTER_LEFT" spacing="10" visible="false" managed="false">
                            <Button text="%menu.btn.volver" styleClass="btn-volver" onAction="#volverAtras" prefHeight="32" prefWidth="90"/>
                            <Label fx:id="labelBreadcrumbs" text="%menu.titulo.principal" styleClass="breadcrumbs-text"/>
                        </HBox>
                    </StackPane>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <VBox alignment="CENTER_RIGHT" spacing="4">
                        <Label fx:id="labelNombreUsuario" text="%menu.cargando" styleClass="menu-usuario-nombre"/>
                        <Label fx:id="labelRolUsuario" text="%menu.rol" styleClass="menu-usuario-rol"/>
                    </VBox>
                    
                    <Button onAction="#cerrarSesion"
                           styleClass="boton-logout"
                           prefHeight="44"
                           prefWidth="44">
                        <graphic>
                            <Region styleClass="icono-logout"/>
                        </graphic>
                    </Button>
                </HBox>
            </StackPane>
            
            <LineaDivisoriaInteractiva/>
        </VBox>
    </top>
    
    <center>
        <StackPane fx:id="contenedorPrincipal" styleClass="contenedor-centro">
            <FondoAnimado fx:id="fondoAnimado"/>
            
            <VBox fx:id="panelInicio" alignment="CENTER" spacing="48" styleClass="menu-contenido">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>
                
                <VBox alignment="CENTER" spacing="12">
                    <Text fx:id="textoBienvenida" text="%menu.bienvenida" styleClass="menu-titulo"/>
                    <Text text="%menu.subtitulo" styleClass="menu-subtitulo"/>
                </VBox>
                
                <GridPane hgap="32" vgap="32" alignment="CENTER" styleClass="menu-grid">
                    
                    <VBox fx:id="opcionFacturar" 
                          alignment="CENTER" 
                          spacing="0" 
                          styleClass="menu-opcion-card"
                          onMouseClicked="#irAFacturar"
                          GridPane.columnIndex="0" 
                          GridPane.rowIndex="0">
                        <padding>
                            <Insets top="50" right="40" bottom="50" left="40"/>
                        </padding>
                        
                        <Label text="%menu.opcion.facturar" styleClass="menu-opcion-titulo"/>
                        <Region styleClass="menu-opcion-linea"/>
                        <Label text="%menu.opcion.facturar.desc" 
                              styleClass="menu-opcion-descripcion"
                              wrapText="true"
                              maxWidth="220"
                              alignment="CENTER"/>
                    </VBox>
                    
                    <VBox fx:id="opcionUsuarios" 
                          alignment="CENTER" 
                          spacing="0" 
                          styleClass="menu-opcion-card"
                          onMouseClicked="#irAUsuarios"
                          GridPane.columnIndex="1" 
                          GridPane.rowIndex="0">
                        <padding>
                            <Insets top="50" right="40" bottom="50" left="40"/>
                        </padding>
                        
                        <Label text="%menu.opcion.usuarios" styleClass="menu-opcion-titulo"/>
                        <Region styleClass="menu-opcion-linea"/>
                        <Label text="%menu.opcion.usuarios.desc" 
                              styleClass="menu-opcion-descripcion"
                              wrapText="true"
                              maxWidth="220"
                              alignment="CENTER"/>
                    </VBox>
                    
                    <VBox fx:id="opcionProductos" 
                          alignment="CENTER" 
                          spacing="0" 
                          styleClass="menu-opcion-card"
                          onMouseClicked="#irAProductos"
                          GridPane.columnIndex="0" 
                          GridPane.rowIndex="1">
                        <padding>
                            <Insets top="50" right="40" bottom="50" left="40"/>
                        </padding>
                        
                        <Label text="%menu.opcion.productos" styleClass="menu-opcion-titulo"/>
                        <Region styleClass="menu-opcion-linea"/>
                        <Label text="%menu.opcion.productos.desc" 
                              styleClass="menu-opcion-descripcion"
                              wrapText="true"
                              maxWidth="220"
                              alignment="CENTER"/>
                    </VBox>
                    
                    <VBox fx:id="opcionReportes" 
                          alignment="CENTER" 
                          spacing="0" 
                          styleClass="menu-opcion-card"
                          onMouseClicked="#irAReportes"
                          GridPane.columnIndex="1" 
                          GridPane.rowIndex="1">
                        <padding>
                            <Insets top="50" right="40" bottom="50" left="40"/>
                        </padding>
                        
                        <Label text="%menu.opcion.reportes" styleClass="menu-opcion-titulo"/>
                        <Region styleClass="menu-opcion-linea"/>
                        <Label text="%menu.opcion.reportes.desc" 
                              styleClass="menu-opcion-descripcion"
                              wrapText="true"
                              maxWidth="220"
                              alignment="CENTER"/>
                    </VBox>
                    
                    <VBox fx:id="opcionConfiguracion" 
                          alignment="CENTER" 
                          spacing="0" 
                          styleClass="menu-opcion-card"
                          onMouseClicked="#irAConfiguracion"
                          GridPane.columnIndex="2" 
                          GridPane.rowIndex="0">
                        <padding>
                            <Insets top="50" right="40" bottom="50" left="40"/>
                        </padding>
                        
                        <Label text="%menu.opcion.configuracion" styleClass="menu-opcion-titulo"/>
                        <Region styleClass="menu-opcion-linea"/>
                        <Label text="%menu.opcion.configuracion.desc" 
                              styleClass="menu-opcion-descripcion"
                              wrapText="true"
                              maxWidth="220"
                              alignment="CENTER"/>
                    </VBox>
                </GridPane>
            </VBox>
            
            <VBox fx:id="panelSeleccionMesero" alignment="CENTER" spacing="32" styleClass="content-container" visible="false" managed="false">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>
                
                <VBox alignment="CENTER" spacing="15">
                    <Text text="%menu.mesa.crear" styleClass="menu-titulo"/>
                    <Text fx:id="txtNombreMesaNueva" text="Mesa: 10" styleClass="search-label, mesa-nueva-label"/>
                    <Text text="%menu.mesa.seleccione_mesero" styleClass="menu-subtitulo"/>
                </VBox>
                
                <ScrollPane fitToWidth="true" maxHeight="500" styleClass="scroll-mesas">
                    <GridPane fx:id="gridMeseros" 
                            hgap="20" 
                            vgap="20" 
                            alignment="CENTER" 
                            styleClass="grid-mesas"
                            prefWidth="800"/>
                </ScrollPane>
                
                <HBox alignment="CENTER" spacing="20">
                    <Button text="%btn.cancelar" 
                           styleClass="btn-cancelar" 
                           onAction="#cancelarCreacionMesa"
                           prefWidth="200" 
                           prefHeight="60"/>
                </HBox>
            </VBox>
            
            <VBox fx:id="panelProductos" alignment="TOP_CENTER" spacing="32" styleClass="content-container" visible="false" managed="false">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>
                
                <Label text="%menu.productos.titulo" styleClass="productos-titulo"/>
                
                <Separator styleClass="separador-dorado" maxWidth="400"/>
                
                <VBox spacing="20" alignment="TOP_CENTER" maxWidth="600">
                    
                    <Button onAction="#productoCrearCategoria" 
                            styleClass="boton-opcion-producto"
                            prefHeight="80"
                            maxWidth="Infinity">
                        <graphic>
                            <HBox alignment="CENTER_LEFT" spacing="20" maxWidth="Infinity">
                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Label text="%menu.productos.crear_categoria" styleClass="opcion-titulo"/>
                                    <Label text="%menu.productos.crear_categoria.desc" styleClass="opcion-subtitulo"/>
                                </VBox>
                                <Label text="→" styleClass="flecha-nav"/>
                            </HBox>
                        </graphic>
                    </Button>
                    
                    <Button onAction="#productoCrearProducto"
                            styleClass="boton-opcion-producto"
                            prefHeight="80"
                            maxWidth="Infinity">
                        <graphic>
                            <HBox alignment="CENTER_LEFT" spacing="20" maxWidth="Infinity">
                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Label text="%menu.productos.crear_producto" styleClass="opcion-titulo"/>
                                    <Label text="%menu.productos.crear_producto.desc" styleClass="opcion-subtitulo"/>
                                </VBox>
                                <Label text="→" styleClass="flecha-nav"/>
                            </HBox>
                        </graphic>
                    </Button>
                    
                    <Button onAction="#productoListarProductos"
                            styleClass="boton-opcion-producto"
                            prefHeight="80"
                            maxWidth="Infinity">
                        <graphic>
                            <HBox alignment="CENTER_LEFT" spacing="20" maxWidth="Infinity">
                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Label text="%menu.productos.listado" styleClass="opcion-titulo"/>
                                    <Label text="%menu.productos.listado.desc" styleClass="opcion-subtitulo"/>
                                </VBox>
                                <Label text="→" styleClass="flecha-nav"/>
                            </HBox>
                        </graphic>
                    </Button>
                    
                    <Button onAction="#productoListarCategorias"
                            styleClass="boton-opcion-producto"
                            prefHeight="80"
                            maxWidth="Infinity">
                        <graphic>
                            <HBox alignment="CENTER_LEFT" spacing="20" maxWidth="Infinity">
                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Label text="%menu.productos.categorias" styleClass="opcion-titulo"/>
                                    <Label text="%menu.productos.categorias.desc" styleClass="opcion-subtitulo"/>
                                </VBox>
                                <Label text="→" styleClass="flecha-nav"/>
                            </HBox>
                        </graphic>
                    </Button>
                    
                    <Button onAction="#productoControlInventario"
                            styleClass="boton-opcion-producto"
                            prefHeight="80"
                            maxWidth="Infinity">
                        <graphic>
                            <HBox alignment="CENTER_LEFT" spacing="20" maxWidth="Infinity">
                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Label text="%menu.productos.inventario" styleClass="opcion-titulo"/>
                                    <Label text="%menu.productos.inventario.desc" styleClass="opcion-subtitulo"/>
                                </VBox>
                                <Label text="→" styleClass="flecha-nav"/>
                            </HBox>
                        </graphic>
                    </Button>
                    
                </VBox>
            </VBox>
            
        </StackPane>
    </center>
    
    <bottom>
        <VBox>
            <LineaDivisoriaInteractiva/>
            
            <StackPane>
                <FondoAnimado colorCentro="#0a0a0a" colorIntermedio="#0a0a0a" colorBorde="#0a0a0a"/>
                <HBox alignment="CENTER" styleClass="menu-footer" spacing="30">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    
                    <HBox alignment="CENTER" spacing="10">
                        <Label fx:id="labelFechaFooter" text="Martes, 07 de enero de 2026" styleClass="menu-footer-text"/>
                        <Label text="|" styleClass="menu-footer-separator"/>
                        <Label fx:id="labelHoraFooter" text="00:00:00" styleClass="menu-footer-text"/>
                    </HBox>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <Label text="%menu.footer.sistema" styleClass="menu-footer-text"/>
                    
                    <Label text="|" styleClass="menu-footer-separator"/>
                    <HBox fx:id="indicadorConexionFooter" alignment="CENTER" spacing="6"/>
                </HBox>
            </StackPane>
        </VBox>
    </bottom>
</BorderPane>
