<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.kipu.cliente.controlador.facturacion.SeleccionMeseroController"
           styleClass="contenedor-centro">
    
    <VBox alignment="TOP_CENTER" spacing="32" styleClass="meseros-container">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        
        <VBox alignment="CENTER" spacing="15">
            <Text text="%menu.mesa.crear" styleClass="menu-titulo"/>
            <Text fx:id="txtNombreMesa" text="Mesa: 10" styleClass="search-label, mesa-nueva-label"/>
            <Text text="%menu.mesa.seleccione_mesero" styleClass="menu-subtitulo"/>
        </VBox>
        
        <HBox alignment="CENTER" spacing="0">
            <HBox alignment="CENTER" spacing="0" styleClass="search-wrapper"
                  maxWidth="520">
                
                <TextField fx:id="txtBuscarMesero" 
                         promptText="%meseros.buscar.prompt.seleccion" 
                         styleClass="search-input"  
                         onAction="#seleccionarPorEnter"
                         prefHeight="45"
                         HBox.hgrow="ALWAYS"/>
                
                <Button styleClass="btn-buscar" 
                       onAction="#seleccionarPorEnter">
                    <HBox.margin>
                        <Insets right="18"/>
                    </HBox.margin>
                    <graphic>
                        <Region styleClass="icono-buscar"/>
                    </graphic>
                </Button>
            </HBox>
        </HBox>
        
        <ScrollPane fitToWidth="true" 
                   styleClass="scroll-meseros"
                   VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER">
                <padding>
                    <Insets top="20" right="40" bottom="20" left="40"/>
                </padding>
                
                <GridPane fx:id="gridMeseros"
                         hgap="20"
                         vgap="20"
                         alignment="TOP_CENTER"
                         styleClass="grid-meseros">
                                        
                </GridPane>
            </HBox>
        </ScrollPane>
        
        <HBox alignment="CENTER" spacing="20">
            <Button text="%btn.cancelar" 
                   onAction="#cancelarSeleccion"
                   styleClass="btn-cancelar"
                   prefWidth="200" 
                   prefHeight="60"/>
        </HBox>
    </VBox>
    
</StackPane>
