<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<!--
    Subvista: Mesas Activas
    Muestra únicamente el grid de mesas activas.
    Sin tabs ni buscadores.
-->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.kipu.cliente.controlador.facturacion.MesasActivasController"
           styleClass="contenedor-centro">
    
    <VBox alignment="TOP_CENTER" spacing="32" styleClass="mesas-activas-container">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        
        <!-- Título -->
        <Text text="%facturacion.mesas_activas.titulo" 
              styleClass="titulo-seccion, titulo-seccion-lg"/>
        
        <!-- Barra de búsqueda -->
        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="txtBusqueda"
                      styleClass="campo-texto, campo-busqueda-mesas"
                      HBox.hgrow="NEVER"/>
        </HBox>
        
        <ScrollPane fx:id="scrollMesas" 
                   fitToWidth="true" 
                   styleClass="scroll-mesas"
                   VBox.vgrow="ALWAYS">
            <content>
                <GridPane fx:id="gridMesas"
                         hgap="20"
                         vgap="20"
                         alignment="TOP_CENTER"
                         styleClass="grid-mesas">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>
                    <!-- Cards se llenan dinámicamente -->
                </GridPane>
            </content>
        </ScrollPane>
    </VBox>

</StackPane>
